<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.trial.mapper.OverdueAlertMapper">
    
    <resultMap type="OverdueAlert" id="OverdueAlertResult">
        <result property="alertId"    column="alert_id"    />
        <result property="alertType"    column="alert_type"    />
        <result property="targetId"    column="target_id"    />
        <result property="targetName"    column="target_name"    />
        <result property="projectId"    column="project_id"    />
        <result property="projectName"    column="project_name"    />
        <result property="alertLevel"    column="alert_level"    />
        <result property="alertStatus"    column="alert_status"    />
        <result property="overdueDays"    column="overdue_days"    />
        <result property="expectedDate"    column="expected_date"    />
        <result property="alertContent"    column="alert_content"    />
        <result property="handler"    column="handler"    />
        <result property="handleTime"    column="handle_time"    />
        <result property="handleRemark"    column="handle_remark"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectOverdueAlertVo">
        select alert_id, alert_type, target_id, target_name, project_id, project_name, alert_level, alert_status, overdue_days, expected_date, alert_content, handler, handle_time, handle_remark, create_by, create_time, update_by, update_time, remark from overdue_alert
    </sql>

    <select id="selectOverdueAlertList" parameterType="OverdueAlert" resultMap="OverdueAlertResult">
        <include refid="selectOverdueAlertVo"/>
        <where>  
            <if test="alertType != null  and alertType != ''"> and alert_type = #{alertType}</if>
            <if test="targetId != null "> and target_id = #{targetId}</if>
            <if test="projectId != null "> and project_id = #{projectId}</if>
            <if test="alertLevel != null  and alertLevel != ''"> and alert_level = #{alertLevel}</if>
            <if test="alertStatus != null  and alertStatus != ''"> and alert_status = #{alertStatus}</if>
            <if test="handler != null  and handler != ''"> and handler = #{handler}</if>
        </where>
        order by create_time desc
    </select>
    
    <select id="selectOverdueAlertById" parameterType="Long" resultMap="OverdueAlertResult">
        <include refid="selectOverdueAlertVo"/>
        where alert_id = #{alertId}
    </select>

    <select id="selectExistingAlert" resultMap="OverdueAlertResult">
        <include refid="selectOverdueAlertVo"/>
        where alert_type = #{alertType} and target_id = #{targetId} and alert_status = #{alertStatus}
        limit 1
    </select>

    <select id="countPendingAlerts" resultType="int">
        select count(*) from overdue_alert where alert_status = 'pending'
    </select>
        
    <insert id="insertOverdueAlert" parameterType="OverdueAlert" useGeneratedKeys="true" keyProperty="alertId">
        insert into overdue_alert
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="alertType != null">alert_type,</if>
            <if test="targetId != null">target_id,</if>
            <if test="targetName != null">target_name,</if>
            <if test="projectId != null">project_id,</if>
            <if test="projectName != null">project_name,</if>
            <if test="alertLevel != null">alert_level,</if>
            <if test="alertStatus != null">alert_status,</if>
            <if test="overdueDays != null">overdue_days,</if>
            <if test="expectedDate != null">expected_date,</if>
            <if test="alertContent != null">alert_content,</if>
            <if test="handler != null">handler,</if>
            <if test="handleTime != null">handle_time,</if>
            <if test="handleRemark != null">handle_remark,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="alertType != null">#{alertType},</if>
            <if test="targetId != null">#{targetId},</if>
            <if test="targetName != null">#{targetName},</if>
            <if test="projectId != null">#{projectId},</if>
            <if test="projectName != null">#{projectName},</if>
            <if test="alertLevel != null">#{alertLevel},</if>
            <if test="alertStatus != null">#{alertStatus},</if>
            <if test="overdueDays != null">#{overdueDays},</if>
            <if test="expectedDate != null">#{expectedDate},</if>
            <if test="alertContent != null">#{alertContent},</if>
            <if test="handler != null">#{handler},</if>
            <if test="handleTime != null">#{handleTime},</if>
            <if test="handleRemark != null">#{handleRemark},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateOverdueAlert" parameterType="OverdueAlert">
        update overdue_alert
        <trim prefix="SET" suffixOverrides=",">
            <if test="alertType != null">alert_type = #{alertType},</if>
            <if test="targetId != null">target_id = #{targetId},</if>
            <if test="targetName != null">target_name = #{targetName},</if>
            <if test="projectId != null">project_id = #{projectId},</if>
            <if test="projectName != null">project_name = #{projectName},</if>
            <if test="alertLevel != null">alert_level = #{alertLevel},</if>
            <if test="alertStatus != null">alert_status = #{alertStatus},</if>
            <if test="overdueDays != null">overdue_days = #{overdueDays},</if>
            <if test="expectedDate != null">expected_date = #{expectedDate},</if>
            <if test="alertContent != null">alert_content = #{alertContent},</if>
            <if test="handler != null">handler = #{handler},</if>
            <if test="handleTime != null">handle_time = #{handleTime},</if>
            <if test="handleRemark != null">handle_remark = #{handleRemark},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where alert_id = #{alertId}
    </update>

    <update id="updateAlertStatusBatch">
        update overdue_alert
        set alert_status = #{alertStatus}, handler = #{handler}, handle_time = now(), handle_remark = #{handleRemark}
        where alert_id in
        <foreach item="alertId" collection="alertIds" open="(" separator="," close=")">
            #{alertId}
        </foreach>
    </update>

    <delete id="deleteOverdueAlertById" parameterType="Long">
        delete from overdue_alert where alert_id = #{alertId}
    </delete>

    <delete id="deleteOverdueAlertByIds" parameterType="String">
        delete from overdue_alert where alert_id in 
        <foreach item="alertId" collection="array" open="(" separator="," close=")">
            #{alertId}
        </foreach>
    </delete>
</mapper>
