    </sql>

    <select id="selectTrialTaskDetailProdList" parameterType="TrialTaskDetailProd"
            resultMap="TrialTaskDetailProdResult">
        <include refid="selectTrialTaskDetailProdVo"/>
        <where>
            <if test="taskId != null">
                and task_id = #{taskId}
            </if>
            <if test="cardType != null  and cardType != ''">
                and card_type = #{cardType}
            </if>
            <if test="columnCode != null">
                and column_code = #{columnCode}
            </if>
            <if test="serialNo != null">
                and serial_no = #{serialNo}
            </if>
            <if test="program != null  and program != ''">
                and program = #{program}
            </if>
            <if test="name != null  and name != ''">
                and name like concat('%', #{name}, '%')
            </if>
            <if test="figure != null  and figure != ''">
                and figure = #{figure}
            </if>
            <if test="trialQuantity != null  and trialQuantity != ''">
                and trial_quantity = #{trialQuantity}
            </if>
            <if test="inspectionQuantity != null  and inspectionQuantity != ''">
                and inspection_quantity = #{inspectionQuantity}
            </if>
            <if test="manufacturingQualityStatus != null  and manufacturingQualityStatus != ''">
                and manufacturing_quality_status = #{manufacturingQualityStatus}
            </if>
            <if test="manufacturingArea != null  and manufacturingArea != ''">
                and manufacturing_area = #{manufacturingArea}
            </if>
            <if test="director != null  and director != ''">
                and director = #{director}
            </if>
            <if test="directorTel != null  and directorTel != ''">
                and director_tel = #{directorTel}
            </if>
            <if test="processQualityStatus != null  and processQualityStatus != ''">
                and process_quality_status = #{processQualityStatus}
            </if>
            <if test="meDirector != null  and meDirector != ''">
                and me_director = #{meDirector}
            </if>
            <if test="meDirectorTel != null  and meDirectorTel != ''">
                and me_director_tel = #{meDirectorTel}
            </if>
            <if test="notes != null  and notes != ''">
                and notes = #{notes}
            </if>
            <if test="status != null  and status != ''">
                and status = #{status}
            </if>
            <if test="urlType != null  and urlType != ''">
                <if test="urlType == 1">
                    and status in (1, 2)
                </if>
            </if>
        </where>
        order by task_id, serial_no
    </select>

    <select id="selectTrialTaskDetailProdById" parameterType="Long" resultMap="TrialTaskDetailProdResult">
        <include refid="selectTrialTaskDetailProdVo"/>
        where id = #{id}
