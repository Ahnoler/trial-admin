    <sql id="selectTrialTaskDetailProdVo">
        select id,
               task_id,
               card_type,
               column_code,
               serial_no,
               program,
               name,
               figure,
               trial_quantity,
               inspection_quantity,
               manufacturing_quality_status,
               manufacturing_area,
               director,
               director_tel,
